# Copy to .env and adjust. Used by docker-compose.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=doublecheck

ASPNETCORE_ENVIRONMENT=Development

# JWT signing. MUST be at least 32 characters. Change for any shared/deployed environment.
JWT_KEY=CHANGE_ME_dev-only-secret-key-min-32-characters-long!!
JWT_ISSUER=DoubleCheck
JWT_AUDIENCE=DoubleCheckClients

# AI provider: "Ollama" (local docker-compose) or "Stub" (no LLM, used in deployment)
AI_PROVIDER=Ollama
AI_MODEL=llama3.2
